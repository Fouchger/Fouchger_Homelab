# ================================================================
# File: ansible/roles/authentik/templates/authentik.env.j2
# Purpose:
#   Environment configuration for the authentik Docker Compose deployment.
#
# Notes:
#   - Replace placeholder secrets with OpenBao-sourced values before use.
# ================================================================

AUTHENTIK_SECRET_KEY={{ authentik_secret_key | default('replace-me-with-openbao-secret') }}
AUTHENTIK_ERROR_REPORTING__ENABLED=false
AUTHENTIK_POSTGRESQL__HOST={{ authentik_postgresql_host | default('postgres') }}
AUTHENTIK_POSTGRESQL__NAME={{ authentik_postgresql_name | default('authentik') }}
AUTHENTIK_POSTGRESQL__USER={{ authentik_postgresql_user | default('authentik') }}
AUTHENTIK_POSTGRESQL__PASSWORD={{ authentik_postgresql_password | default('replace-me') }}
AUTHENTIK_REDIS__HOST={{ authentik_redis_host | default('redis') }}
AUTHENTIK_BOOTSTRAP_EMAIL={{ authentik_bootstrap_email | default('akadmin@lab.local') }}
AUTHENTIK_BOOTSTRAP_PASSWORD={{ authentik_bootstrap_password | default('replace-me') }}
AUTHENTIK_BOOTSTRAP_TOKEN={{ authentik_bootstrap_token | default('replace-me') }}
AUTHENTIK_DISABLE_STARTUP_ANALYTICS=true
