# ================================================================
# File: .gitignore
# Purpose:
#   Ignore transient plaintext and local runtime artefacts.
# Notes:
#   - Encrypted artefacts under state/secrets/ should be committed only
#     where appropriate for your repo policy.
#   - Plaintext bootstrap outputs, tokens, and keys should not be committed.
# ================================================================

# Temporary plaintext working files
state/secrets/.tmp/

# State files
state/

# Local editor and OS noise
.DS_Store
*.swp
*.swo

# Python cache if helper scripts are added later
__pycache__/
*.pyc

# Optional local env files outside SOPS control
.env.local
.envrc.local
