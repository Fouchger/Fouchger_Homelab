# ################################################################
# File: config/examples/state.env.example
# Created: 2026/03/07
# Updated: 2026/03/07
# Description:
#   Canonical local environment settings for homelab bootstrap and runtime.
# Notes:
#   - Generated by install.sh to keep the example and active local env aligned.
#   - Keep values simple KEY=VALUE format.
#   - Multi-line values are intentionally not supported here.
# ################################################################

REPO_DIR=
GITHUB_REPO=Fouchger/Fouchger_Homelab
GITHUB_BRANCH=branch1
SETUP=prod
NONINTERACTIVE=0
ENABLE_OPENBAO_BOOTSTRAP=0
OPENBAO_ADDR=
OPENBAO_CACERT=
OPENBAO_SKIP_VERIFY=false
OPENBAO_INIT_SHARES=5
OPENBAO_INIT_THRESHOLD=3
OPENBAO_TRANSIT_MOUNT=transit
OPENBAO_TRANSIT_KEY=autounseal
OPENBAO_TRANSIT_POLICY=autounseal
OPENBAO_TRANSIT_TOKEN_PERIOD=720h
