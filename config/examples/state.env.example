# ################################################################
# File: config/examples/state.env.example
# Created: 2026/03/07
# Updated: 2026/03/07
# Description:
#   Example local environment file copied to state/configs/.env during bootstrap.
# Notes:
#   - This file is safe to keep in Git because it contains placeholders only.
#   - Adjust values after the initial copy if you want local overrides.
# ################################################################

REPO_DIR=
GITHUB_REPO=Fouchger/Fouchger_Homelab
GITHUB_BRANCH=branch1
SETUP=prod
NONINTERACTIVE=0
ENABLE_OPENBAO_BOOTSTRAP=0
OPENBAO_ADDR=
OPENBAO_CACERT=
OPENBAO_SKIP_VERIFY=false
OPENBAO_INIT_SHARES=5
OPENBAO_INIT_THRESHOLD=3
OPENBAO_TRANSIT_MOUNT=transit
OPENBAO_TRANSIT_KEY=autounseal
OPENBAO_TRANSIT_POLICY=autounseal
OPENBAO_TRANSIT_TOKEN_PERIOD=720h
